{
  "name": "logseq-sidebar-calendar-plugin",
  "version": "0.1.0",
  "type": "module",
  "description": "A persistent, interactive bottom-left calendar widget for Logseq with ISO week numbers and custom date formatting.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "zip": "zip -r logseq-sidebar-calendar-plugin.zip dist package.json"
  },
  "logseq": {
