    "title": "Sidebar Calendar",
    "icon": "./icon.png",
    "main": "dist/index.html"
  },
  "devDependencies": {
    "@logseq/libs": "^0.0.17",
    "typescript": "^6.0.3",
    "vite": "^5.2.0"
  },
  "license": "MIT",
  "dependencies": {
    "date-fns": "^4.4.0"
  }
}